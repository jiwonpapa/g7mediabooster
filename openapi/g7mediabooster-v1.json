  "components": {
    "schemas": {
      "CapabilitiesResponse": {
        "type": "object",
        "description": "Runtime media capability response.",
        "required": [
          "image_inputs",
          "image_outputs",
          "video_inputs",
          "mp4_thumbnail",
          "mp4_h264_fallback",
          "native_versions"
        ],
        "properties": {
          "image_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Formats the native runtime can decode in this deployment."
          },
          "image_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Formats the native runtime can encode in this deployment."
          },
          "mp4_h264_fallback": {
            "type": "boolean",
            "description": "Whether the narrow MP4/H.264 OpenH264 fallback is compiled into the sandbox."
          },
          "mp4_thumbnail": {
            "type": "boolean",
            "description": "Whether FFprobe and FFmpeg passed the embedded MP4/H.264 runtime fixture."
          },
          "native_versions": {
            "type": "object",
            "description": "Sanitized version lines from the native tools checked by the sandbox.",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "video_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Video containers that passed probe and poster extraction fixtures."
          }
        }
      },
      "CompleteMultipartUploadRequest": {
        "type": "object",
        "description": "Finalizes a previously created multipart upload.",
        "required": [
          "parts"
        ],
        "properties": {
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompletedUploadPart"
            },
            "description": "Ordered, unique completed parts.",
            "maxItems": 10000,
            "minItems": 1
          }
        }
      },
      "CompletedUploadPart": {
        "type": "object",
        "description": "One completed multipart part supplied to the finalization call.",
        "required": [
          "part_number",
          "etag"
        ],
        "properties": {
          "etag": {
            "type": "string",
            "description": "Opaque provider ETag returned by the part upload."
          },
          "part_number": {
            "type": "integer",
            "format": "int32",
            "description": "One-based part number.",
            "maximum": 10000,
            "minimum": 1
          }
        }
      },
      "CreateUploadBatchRequest": {
        "type": "object",
        "description": "Creates direct-upload reservations for multiple files at once.",
        "required": [
          "files"
        ],
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UploadFileIntentRequest"
            },
            "description": "One to one hundred file reservations.",
            "maxItems": 100,
            "minItems": 1
          }
        }
      },
      "CreateUploadBatchResponse": {
        "type": "object",
        "description": "Result of creating one bounded multi-upload batch.",
        "required": [
          "batch_id",
          "uploads"
        ],
        "properties": {
          "batch_id": {
            "type": "string",
            "format": "uuid",
            "description": "Server-generated batch identifier."
          },
          "uploads": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UploadIntentResponse"
            },
            "description": "Response instructions in request order."
          }
        }
      },
      "DerivativeDeliveryResponse": {
        "type": "object",
        "description": "Short-lived private derivative delivery returned to the trusted PHP module.",
        "required": [
          "upload_id",
          "preset_id",
          "variant",
          "delivery_url",
          "expires_at",
          "content_type",
          "byte_len"
        ],
        "properties": {
          "byte_len": {
            "type": "integer",
            "format": "int64",
            "description": "Exact encoded output length.",
            "minimum": 0
          },
          "content_type": {
            "type": "string",
            "description": "Trusted encoded content type."
          },
          "delivery_url": {
            "type": "string",
            "description": "Sensitive provider GET URL. It must never be logged."
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "description": "Provider signature expiration."
          },
          "preset_id": {
            "type": "string",
            "description": "Versioned transformation preset."
          },
          "upload_id": {
            "type": "string",
            "format": "uuid",
            "description": "Upload owning the immutable derivative."
          },
          "variant": {
            "type": "string",
            "description": "Stable `master` or `thumbnail` variant."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Stable error envelope returned to API consumers.",
        "required": [
          "code",
          "message",
          "request_id"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Stable machine-readable error code."
          },
          "message": {
            "type": "string",
            "description": "User-safe explanation without backend details."
          },
          "request_id": {
            "type": "string",
            "description": "Correlation identifier for support and logs."
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "description": "Health endpoint response.",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "`live` or `ready`."
          },
          "version": {
            "type": "string",
            "description": "Running package version."
          }
        }
      },
      "PresignUploadPartRequest": {
        "type": "object",
        "description": "Request for a short-lived URL for one multipart part.",
        "required": [
          "content_length"
        ],
        "properties": {
          "content_length": {
            "type": "integer",
            "format": "int64",
            "description": "Exact part length; only the final part may be below 5 MiB.",
            "minimum": 1
          }
        }
      },
      "PresignUploadPartResponse": {
        "type": "object",
        "description": "Short-lived direct upload URL for one multipart part.",
        "required": [
          "part_number",
          "upload_url",
          "required_headers",
          "expires_at"
        ],
        "properties": {
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "description": "Signature expiration."
          },
          "part_number": {
            "type": "integer",
            "format": "int32",
            "description": "One-based part number covered by the signature.",
            "minimum": 0
          },
          "required_headers": {
            "type": "object",
            "description": "Signed request headers.",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "upload_url": {
            "type": "string",
            "description": "Sensitive presigned URL. API logs must redact it."
          }
        }
      },
      "PublishSitePolicyRequest": {
        "type": "object",
        "description": "HMAC-authenticated next site policy revision published by the PHP module.",
        "required": [
          "schema_version",
          "revision",
          "issued_at"
        ],
        "properties": {
          "issued_at": {
            "type": "integer",
            "format": "int64",
            "description": "Unix issuance timestamp covered by the request signature."
          },
          "revision": {
            "type": "integer",
            "format": "int64",
            "description": "Strictly increasing tenant revision starting at one.",
            "minimum": 1
          },
          "schema_version": {
            "type": "integer",
            "format": "int32",
            "description": "Must equal the v1 policy schema.",
            "minimum": 0
          },
          "watermark": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SitePolicyWatermarkRequest",
                "description": "`null` explicitly disables watermarking."
              }
            ]
          }
        }
      },
      "SitePolicySnapshotResponse": {
        "type": "object",
        "description": "Active immutable site policy snapshot.",
        "required": [
          "schema_version",
          "revision",
          "issued_at",
          "settings_sha256"
        ],
        "properties": {
          "issued_at": {
            "type": "integer",
            "format": "int64",
            "description": "Original signed issuance timestamp."
          },
          "revision": {
            "type": "integer",
            "format": "int64",
            "description": "Active tenant revision.",
            "minimum": 0
          },
          "schema_version": {
            "type": "integer",
            "format": "int32",
            "description": "Stable policy schema version.",
            "minimum": 0
          },
          "settings_sha256": {
            "type": "string",
            "description": "Rust-computed normalized settings hash."
          },
          "watermark": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SitePolicyWatermarkResponse",
                "description": "`null` means watermarking is disabled."
              }
            ]
          }
        }
      },
      "SitePolicyWatermarkPosition": {
        "type": "string",
        "description": "Allowlisted watermark anchor in a signed site policy snapshot.",
        "enum": [
          "center",
          "top_left",
          "top_right",
          "bottom_left",
          "bottom_right"
        ]
      },
      "SitePolicyWatermarkRequest": {
        "type": "object",
        "description": "Admin-selected watermark settings referencing an already validated image upload.",
        "required": [
          "asset_upload_id",
          "position",
          "margin_px",
          "max_width_percent",
          "opacity_percent"
        ],
        "properties": {
          "asset_upload_id": {
            "type": "string",
            "format": "uuid",
            "description": "Tenant-owned Ready image upload selected as the source asset."
          },
          "margin_px": {
            "type": "integer",
            "format": "int32",
            "description": "Safe edge margin.",
            "maximum": 1024,
            "minimum": 0
          },
          "max_width_percent": {
            "type": "integer",
            "format": "int32",
            "description": "Maximum derivative width percentage.",
            "maximum": 50,
            "minimum": 1
          },
          "opacity_percent": {
            "type": "integer",
            "format": "int32",
            "description": "Alpha multiplier percentage.",
            "maximum": 100,
            "minimum": 1
          },
          "position": {
            "$ref": "#/components/schemas/SitePolicyWatermarkPosition",
            "description": "Allowlisted overlay anchor."
          }
        }
      },
      "SitePolicyWatermarkResponse": {
        "type": "object",
        "description": "Pinned watermark facts returned from durable policy state.",
        "required": [
          "asset_upload_id",
          "asset_sha256",
          "position",
          "margin_px",
          "max_width_percent",
          "opacity_percent"
        ],
        "properties": {
          "asset_sha256": {
            "type": "string",
            "description": "Lowercase source digest independently captured by Rust."
          },
          "asset_upload_id": {
            "type": "string",
            "format": "uuid",
            "description": "Original admin-selected upload."
          },
          "margin_px": {
            "type": "integer",
            "format": "int32",
            "description": "Safe edge margin.",
            "minimum": 0
          },
          "max_width_percent": {
            "type": "integer",
            "format": "int32",
            "description": "Maximum derivative width percentage.",
            "minimum": 0
          },
          "opacity_percent": {
            "type": "integer",
            "format": "int32",
            "description": "Alpha multiplier percentage.",
            "minimum": 0
          },
          "position": {
            "$ref": "#/components/schemas/SitePolicyWatermarkPosition",
            "description": "Allowlisted overlay anchor."
          }
        }
      },
      "UploadDerivativeResponse": {
        "type": "object",
        "description": "One immutable generated derivative.",
        "required": [
          "preset_id",
          "variant",
          "url_path",
          "content_type",
          "byte_len"
        ],
        "properties": {
          "byte_len": {
            "type": "integer",
            "format": "int64",
            "description": "Exact encoded output length.",
            "minimum": 0
          },
          "content_type": {
            "type": "string",
            "description": "Trusted output content type."
          },
          "preset_id": {
            "type": "string",
            "description": "Versioned transformation preset."
          },
          "url_path": {
            "type": "string",
            "description": "CDN-relative immutable media path."
          },
          "variant": {
            "type": "string",
            "description": "Stable output variant."
          }
        }
      },
      "UploadFileIntentRequest": {
        "type": "object",
        "description": "One file requested inside a bounded multi-upload batch.",
        "required": [
          "client_ref",
          "declared_kind",
          "content_length",
          "content_type_hint"
        ],
        "properties": {
          "client_ref": {
            "type": "string",
            "description": "Caller-generated opaque identifier used only to match batch responses."
          },
          "content_length": {
            "type": "integer",
            "format": "int64",
            "description": "Exact byte length covered by the direct-upload reservation.",
            "minimum": 1
          },
          "content_type_hint": {
            "type": "string",
            "description": "Untrusted MIME hint retained for diagnostics and signing."
          },
          "declared_kind": {
            "$ref": "#/components/schemas/UploadKind",
            "description": "Client-declared media class. The worker verifies the actual bytes later."
          }
        }
      },
      "UploadIntentResponse": {
        "type": "object",
        "description": "One file reservation returned from a batch request.",
        "required": [
          "client_ref",
          "upload_id",
          "method",
          "required_headers",
          "expires_at"
        ],
        "properties": {
          "client_ref": {
            "type": "string",
            "description": "Echo of the request identifier."
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "description": "Reservation and any returned signature expiration."
          },
          "method": {
            "$ref": "#/components/schemas/UploadMethod",
            "description": "Selected direct-upload strategy."
          },
          "part_size_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Planned part size for multipart uploads.",
            "minimum": 0
          },
          "required_headers": {
            "type": "object",
            "description": "Headers that must be sent exactly as signed.",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "upload_id": {
            "type": "string",
            "format": "uuid",
            "description": "Server-generated media upload identifier."
          },
          "upload_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "Presigned URL for single PUT. Multipart uploads presign parts separately."
          }
        }
      },
      "UploadKind": {
        "type": "string",
        "description": "Client-declared media class used to reserve a safe byte budget.",
        "enum": [
          "image",
          "video"
        ]
      },
      "UploadMethod": {
        "type": "string",
        "description": "Direct-upload strategy selected by server policy.",
        "enum": [
          "single_put",
          "multipart"
        ]
      },
      "UploadStatusResponse": {
        "type": "object",
        "description": "Tenant-scoped upload and derivative status.",
        "required": [
          "upload_id",
          "state",
          "deletion_pending",
          "derivatives"
        ],
        "properties": {
          "deletion_pending": {
            "type": "boolean",
            "description": "Whether irreversible object cleanup is durably queued."
          },
          "derivatives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UploadDerivativeResponse"
            },
            "description": "Immutable derivatives available to the application."
          },
          "detected_content_type": {
            "type": [
              "string",
              "null"
            ],
            "description": "Trusted detected source content type after validation."
          },
          "error_code": {
            "type": [
              "string",
              "null"
            ],
            "description": "Stable rejection or failure code without backend details."
          },
          "state": {
            "$ref": "#/components/schemas/UploadStatusValue",
            "description": "Current lifecycle state."
          },
          "upload_id": {
            "type": "string",
            "format": "uuid",
            "description": "Upload identifier."
          }
        }
      },
      "UploadStatusValue": {
        "type": "string",
        "description": "Public upload lifecycle value returned to the authenticated PHP module.",
        "enum": [
          "created",
          "uploaded",
          "quarantined",
          "processing",
          "ready",
          "rejected",
          "failed",
          "deleted"
        ]
      }
    }
