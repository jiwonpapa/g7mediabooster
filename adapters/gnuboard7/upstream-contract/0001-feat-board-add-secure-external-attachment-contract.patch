@@ -0,0 +1,62 @@
+<?php
+
+namespace Modules\Sirsoft\Board\Tests\Unit;
+
+require_once __DIR__.'/../ModuleTestCase.php';
+
+use App\Extension\HookManager;
+use Modules\Sirsoft\Board\Models\Attachment;
+use Modules\Sirsoft\Board\Models\Board;
+use Modules\Sirsoft\Board\Tests\ModuleTestCase;
+use PHPUnit\Framework\Attributes\Test;
+
+class AttachmentUrlFilterTest extends ModuleTestCase
+{
+    protected function tearDown(): void
+    {
+        HookManager::clearFilter('sirsoft-board.attachment.filter_download_url');
+        HookManager::clearFilter('sirsoft-board.attachment.filter_preview_url');
+        parent::tearDown();
+    }
+
+    #[Test]
+    public function external_storage_module_can_replace_download_and_preview_urls(): void
+    {
+        $attachment = new Attachment([
+            'hash' => 'abc123def456',
+            'mime_type' => 'image/jpeg',
+        ]);
+        $board = new Board(['slug' => 'notice']);
+        $attachment->setRelation('board', $board);
+
+        HookManager::addFilter(
+            'sirsoft-board.attachment.filter_download_url',
+            static fn (string $url, Attachment $model): string => '/external/'.$model->hash.'/master',
+        );
+        HookManager::addFilter(
+            'sirsoft-board.attachment.filter_preview_url',
+            static fn (string $url, Attachment $model): string => '/external/'.$model->hash.'/thumbnail',
+        );
+
+        $this->assertSame('/external/abc123def456/master', $attachment->download_url);
+        $this->assertSame('/external/abc123def456/thumbnail', $attachment->preview_url);
+    }
+
+    #[Test]
+    public function external_storage_module_can_publish_a_video_poster_url(): void
+    {
+        $attachment = new Attachment([
+            'hash' => 'abc123def456',
+            'mime_type' => 'video/mp4',
+        ]);
+        $board = new Board(['slug' => 'notice']);
+        $attachment->setRelation('board', $board);
+
+        HookManager::addFilter(
+            'sirsoft-board.attachment.filter_preview_url',
+            static fn (?string $url, Attachment $model, ?string $slug): string => '/external/'.$slug.'/'.$model->hash.'/thumbnail',
+        );
+
+        $this->assertSame('/external/notice/abc123def456/thumbnail', $attachment->preview_url);
+    }
+}
