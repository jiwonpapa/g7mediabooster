+    /**
+     * 게시글 본문에서 가려지는 첨부가 직접 URL로 우회되지 않도록 검사합니다.
+     */
+    private function assertPostAttachmentAccess(string $slug, Attachment $attachment, string $context): void
+    {
+        if (! $attachment->post_id) {
+            return;
+        }
+
+        $post = $this->repository->findPostForAttachmentDelivery($slug, (int) $attachment->post_id);
+        if ($post === null) {
+            throw new AccessDeniedHttpException(__('auth.scope_denied'));
+        }
+
+        $isDeleted = $post->deleted_at !== null || $post->status === PostStatus::Deleted;
+        $isBlinded = $post->status === PostStatus::Blinded;
+        if (! $isDeleted && ! $isBlinded && ! $post->is_secret) {
+            return;
+        }
+
+        $user = Auth::user();
+        $isOwner = $user !== null && $post->user_id !== null && (int) $post->user_id === (int) $user->id;
+        $managePermission = $context === 'admin'
+            ? "sirsoft-board.{$slug}.admin.manage"
+            : "sirsoft-board.{$slug}.manager";
+
+        if ($isDeleted) {
+            if (! PermissionHelper::check($managePermission)) {
+                throw new AccessDeniedHttpException(__('auth.scope_denied'));
+            }
+
+            return;
+        }
+
+        if ($isBlinded) {
+            if (! $isOwner && ! PermissionHelper::check($managePermission)) {
+                throw new AccessDeniedHttpException(__('auth.scope_denied'));
+            }
+
+            return;
+        }
+
+        if ($post->is_secret) {
+            $readSecretPermission = $context === 'admin'
+                ? "sirsoft-board.{$slug}.admin.posts.read-secret"
+                : "sirsoft-board.{$slug}.posts.read-secret";
+            if (! $isOwner
+                && ! PermissionHelper::check($managePermission)
+                && ! PermissionHelper::check($readSecretPermission)
+            ) {
+                throw new AccessDeniedHttpException(__('auth.scope_denied'));
+            }
+        }
+    }
