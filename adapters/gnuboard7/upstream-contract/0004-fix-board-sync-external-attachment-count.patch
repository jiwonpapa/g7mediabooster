+    /**
+     * ID 기반 임시 첨부 연결은 bulk update라 모델 훅을 발화하지 않는다.
+     * 게시글 생성 응답 시점에 attachments_count가 실제 연결 수와 같아야 한다.
+     */
+    public function test_post_create_with_attachment_ids_syncs_attachments_count(): void
+    {
+        $user = User::factory()->create();
+        $this->actingAs($user);
+
+        $attachment = Attachment::create([
+            'board_id' => 0,
+            'post_id' => null,
+            'temp_key' => null,
+            'original_filename' => 'external.jpg',
+            'stored_filename' => 'external.jpg',
+            'disk' => 'external-media',
+            'path' => '019f66a7-0000-7000-8000-000000000001',
+            'mime_type' => 'image/jpeg',
+            'size' => 1024,
+            'collection' => 'post_attachments',
+            'order' => 1,
+            'created_by' => $user->id,
+        ]);
+
+        $post = app(PostService::class)->createPost(
+            $this->slug,
+            [
+                'user_id' => $user->id,
+                'title' => '외부 첨부 카운트',
+                'content' => '본문',
+                'content_mode' => 'text',
+                'author_name' => $user->name,
+                'ip_address' => '127.0.0.1',
+                'is_notice' => false,
+                'is_secret' => false,
+            ],
+            attachmentIds: [$attachment->id],
+        );
+
+        $this->assertSame(1, $post->refresh()->attachments_count);
+        $this->assertSame($post->id, $attachment->refresh()->post_id);
+    }
